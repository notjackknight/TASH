# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ─── Square Integration ──────────────────────────────────────
# Get these from: https://developer.squareup.com → your application → Credentials

# Server-side only (Cloudflare Pages Functions env vars — set in Cloudflare Dashboard)
SQUARE_ACCESS_TOKEN=""           # Credentials → Access Token
SQUARE_LOCATION_ID=""            # Dashboard → Locations → your location → Location ID
SQUARE_ENVIRONMENT="sandbox"     # "sandbox" for testing, "production" for live

# Frontend-safe (exposed to browser via Vite — prefixed with VITE_)
VITE_SQUARE_BOOKING_URL=""       # Square Online Booking page URL (for "My Appointments" nav link)
